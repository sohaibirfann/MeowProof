<Window x:Class="MeowProof.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:MeowProof.UI.Controls"
        Title="MeowProof"
        Width="380" Height="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource UiFont}" Foreground="{StaticResource Text}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Window.Resources>
        <!-- Lock button gradient, matching the mockup: linear-gradient(160deg, #D98C66, #B0633F). -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0.33,0.03" EndPoint="0.67,0.97">
            <GradientStop Color="#D98C66" Offset="0" />
            <GradientStop Color="{StaticResource AccentDeepColor}" Offset="1" />
        </LinearGradientBrush>

        <!-- Primary action button: appearance is driven from code-behind. -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}"
            BorderThickness="1" CornerRadius="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ===== Title bar ===== -->
            <Border Grid.Row="0" Height="46" BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="0,0,0,1" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="14,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Border Width="24" Height="24" CornerRadius="7" Background="{StaticResource AccentGradient}">
                            <!-- mini cat loaf (white) -->
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="116" Height="108">
                                    <Path Fill="White" Data="M30,56 L33,18 L58,50 Z" />
                                    <Path Fill="White" Data="M58,50 L83,18 L86,56 Z" />
                                    <Path Fill="White" Data="M12,100 C12,54 30,42 58,42 C86,42 104,54 104,100 Z" />
                                    <Path Stroke="White" StrokeThickness="11" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="{x:Null}" Data="M104,92 c15,1 14,-18 1,-17" />
                                    <Path Stroke="{StaticResource AccentDeep}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="{x:Null}" Data="M40,74 q6,5 12,0" />
                                    <Path Stroke="{StaticResource AccentDeep}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="{x:Null}" Data="M64,74 q6,5 12,0" />
                                    <Path Fill="{StaticResource AccentDeep}" Data="M58,79 l-4,4 h8 Z" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="MeowProof" Margin="9,0,0,0" VerticalAlignment="Center"
                                   FontSize="13.5" FontWeight="Bold" Foreground="{StaticResource Text}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Style="{StaticResource WinButton}" Click="Minimize_Click" ToolTip="Minimize">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8" StrokeStartLineCap="Round" Data="M5,12 H19" Width="18" Height="14" Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource WinCloseButton}" Click="Close_Click" ToolTip="Close">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8" StrokeStartLineCap="Round" Data="M6,6 L18,18 M18,6 L6,18" Width="14" Height="14" Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Body ===== -->
            <Grid Grid.Row="1" Margin="20,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Hero / status -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="150" Height="150">
                        <Ellipse x:Name="HeroGlow" Width="170" Height="170" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{StaticResource AccentGlowColor}" Offset="0" />
                                    <GradientStop Color="#00CC7C57" Offset="0.7" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <ctl:CatHero x:Name="Hero" Width="118" Height="128"
                                     Fill="{StaticResource TextDim}" />
                    </Grid>
                    <TextBlock x:Name="StatusText" Text="Keyboard Unlocked" Margin="0,8,0,0"
                               FontSize="19" FontWeight="ExtraBold" HorizontalAlignment="Center"
                               Foreground="{StaticResource Text}" />
                    <Border x:Name="StatusPill" Margin="0,10,0,0" HorizontalAlignment="Center"
                            Height="26" CornerRadius="13" Padding="9,0,11,0" Background="{StaticResource Surface2}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="PillDot" Width="7" Height="7" Fill="{StaticResource Sage}" />
                            <TextBlock x:Name="PillText" Text="Ready" Margin="7,0,0,0" FontSize="12"
                                       FontWeight="Bold" Foreground="{StaticResource Sage}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <Button x:Name="PrimaryActionButton" Style="{StaticResource PrimaryButton}" Click="Primary_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path x:Name="PrimaryIcon" Width="18" Height="18" Stretch="Uniform"
                                  Stroke="#FFFFFF" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="Transparent"
                                  Data="M5,11 h14 v9 h-14 Z M8,11 V7.5 a4,4 0 0 1 8,0 V11" />
                            <TextBlock x:Name="PrimaryText" Text="Lock Keyboard" Margin="9,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Click="Stealth_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource TextDim}"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                      Data="M3,3 L21,21 M10.6,6.2 A9.7,9.7 0 0 1 12,6 C17,6 21,12 21,12 a16,16 0 0 1 -2.3,2.8 M6.3,7.9 C4,9.6 3,12 3,12 s4,6 9,6 a8.7,8.7 0 0 0 3.3,-0.65 M9.9,9.9 a3,3 0 0 0 4.2,4.2" />
                                <TextBlock Text="Stealth Lock" Margin="7,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="Settings_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Canvas Width="16" Height="16">
                                    <Path Stroke="{StaticResource TextDim}" StrokeThickness="1.2" StrokeStartLineCap="Round"
                                          Data="M2.7,5.3 h6.7 M12,5.3 h1.3 M2.7,10.7 h1.3 M6.7,10.7 h6.7" />
                                    <Ellipse Canvas.Left="9.2" Canvas.Top="3.8" Width="3" Height="3"
                                             Stroke="{StaticResource TextDim}" StrokeThickness="1.2" />
                                    <Ellipse Canvas.Left="3.8" Canvas.Top="9.2" Width="3" Height="3"
                                             Stroke="{StaticResource TextDim}" StrokeThickness="1.2" />
                                </Canvas>
                                <TextBlock Text="Settings" Margin="7,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Shortcut hint -->
                    <StackPanel x:Name="ShortcutHint" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="Press" VerticalAlignment="Center" FontSize="11.5"
                                   Foreground="{StaticResource TextFaint}" />
                        <Border Style="{x:Null}" Margin="5,0,0,0" CornerRadius="6" Padding="7,1"
                                Background="{StaticResource Surface2}" BorderBrush="{StaticResource Border}" BorderThickness="1,1,1,2">
                            <TextBlock Text="Ctrl" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" />
                        </Border>
                        <TextBlock Text="+" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource TextFaint}" />
                        <Border Margin="4,0,0,0" CornerRadius="6" Padding="7,1"
                                Background="{StaticResource Surface2}" BorderBrush="{StaticResource Border}" BorderThickness="1,1,1,2">
                            <TextBlock Text="Shift" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" />
                        </Border>
                        <TextBlock Text="+" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource TextFaint}" />
                        <Border Margin="4,0,0,0" CornerRadius="6" Padding="7,1"
                                Background="{StaticResource Surface2}" BorderBrush="{StaticResource Border}" BorderThickness="1,1,1,2">
                            <TextBlock Text="L" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" />
                        </Border>
                        <TextBlock Text="to lock from anywhere" Margin="5,0,0,0" VerticalAlignment="Center"
                                   FontSize="11.5" Foreground="{StaticResource TextFaint}" />
                    </StackPanel>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Height="38" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0">
                    <Grid>
                        <TextBlock Text="v1.0.0" VerticalAlignment="Center" HorizontalAlignment="Left"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextFaint}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
