<Window x:Class="MeowProof.UI.SoundPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Sound" Width="360" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        FontFamily="/Assets/Fonts/#Manrope" Foreground="{StaticResource Text}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}"
            BorderThickness="1" CornerRadius="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Height="46" BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="14,0,10,0">
                    <TextBlock Text="Choose Sound" VerticalAlignment="Center"
                               FontSize="13.5" FontWeight="Bold" Foreground="{StaticResource Text}" />
                    <Button Style="{StaticResource WinCloseButton}" HorizontalAlignment="Right"
                            Click="Cancel_Click" ToolTip="Cancel">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Data="M6,6 L18,18 M18,6 L6,18"
                              Width="14" Height="14" Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <!-- Sound list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="340">
                <StackPanel Margin="12,10,12,10" x:Name="SoundList" />
            </ScrollViewer>

            <!-- Bottom bar -->
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0">
                <Grid Margin="14,12,14,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Import custom -->
                    <Button Grid.Column="0" x:Name="ImportButton" Click="Import_Click"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="0">
                        <TextBlock FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Accent}"
                                   Text="+ Import Custom..." />
                    </Button>

                    <Button Grid.Column="1" Content="Cancel" Click="Cancel_Click"
                            Width="80" Height="32"
                            Style="{StaticResource SecondaryButton}" />

                    <Button Grid.Column="3" Content="Save" Click="Save_Click"
                            Width="80" Height="32"
                            Style="{StaticResource PrimaryButton}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
