<Window x:Class="MeowProof.UI.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="272" SizeToContent="Height"
        Left="-10000" Top="-10000" Opacity="0"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" ShowActivated="True"
        FontFamily="{StaticResource UiFont}" Foreground="{StaticResource Text}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border Margin="18" Background="{StaticResource Bg}"
            BorderBrush="{StaticResource Border}" BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <!-- Keep BlurRadius within the Margin so the soft shadow fades out
                 inside the transparent window instead of clipping to a hard edge.
                 DropShadowEffect takes its alpha from Opacity, not the colour. -->
            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Direction="270"
                              Color="#000000" Opacity="0.18" RenderingBias="Quality"/>
        </Border.Effect>

        <StackPanel>

            <!-- Header: icon + name + state -->
            <Grid Margin="14,14,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Mini cat loaf icon -->
                <Border Width="34" Height="34" CornerRadius="10"
                        Background="{StaticResource AccentSoft}">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="116" Height="108">
                            <Path Fill="{StaticResource Accent}" Data="M30,56 L33,18 L58,50 Z" />
                            <Path Fill="{StaticResource Accent}" Data="M86,56 L83,18 L58,50 Z" />
                            <Path Fill="{StaticResource Accent}">
                                <Path.Data>
                                    M22,56 C22,52 26,50 30,50
                                    L86,50 C90,50 94,52 94,56
                                    L94,88 C94,96 88,102 80,102
                                    L36,102 C28,102 22,96 22,88 Z
                                </Path.Data>
                            </Path>
                            <Path Fill="{StaticResource AccentDeep}" Data="M44,72 C44,68 52,66 58,66 C64,66 72,68 72,72 C72,76 64,78 58,78 C52,78 44,76 44,72 Z" />
                            <Path Fill="{StaticResource AccentDeep}" Data="M58,79 l-4,4 h8 Z" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="MeowProof" FontSize="13.5" FontWeight="Bold" />
                    <TextBlock x:Name="StatusLabel" FontSize="11.5"
                               Foreground="{StaticResource TextFaint}" Margin="0,1,0,0" />
                </StackPanel>
            </Grid>

            <!-- Lock / Unlock button -->
            <Button x:Name="LockBtn" Margin="12,0,12,14" Height="38"
                    Click="LockBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <Path x:Name="LockIcon" Width="13" Height="13" Stretch="Uniform"
                          Data="M8,1 A4,4 0 0 1 12,5 L12,7 L4,7 L4,5 A4,4 0 0 1 8,1 Z M3,7 H13 V15 H3 Z"
                          Fill="White" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <TextBlock x:Name="LockBtnText" FontSize="13.5" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Divider -->
            <Border BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0" />

            <!-- Toggles -->
            <Grid Margin="14,11,14,7">
                <TextBlock Text="Launch at Login" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <ToggleButton x:Name="ToggleLogin" Style="{StaticResource ToggleSwitch}"
                              HorizontalAlignment="Right"
                              Checked="ToggleLogin_Changed" Unchecked="ToggleLogin_Changed" />
            </Grid>
            <Grid Margin="14,4,14,11">
                <TextBlock Text="Stealth Lock" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <ToggleButton x:Name="ToggleStealth" Style="{StaticResource ToggleSwitch}"
                              HorizontalAlignment="Right"
                              Checked="ToggleStealth_Changed" Unchecked="ToggleStealth_Changed" />
            </Grid>

            <!-- Divider -->
            <Border BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0" />

            <!-- Menu actions -->
            <StackPanel Margin="6,6,6,6">

                <Button Style="{StaticResource MenuItemButton}" Click="Open_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="13" Height="13" Stretch="Uniform" Margin="0,0,9,0"
                              Fill="{StaticResource TextDim}"
                              Data="M2,3 H9 V10 H2 Z M7,1 H15 V9 H7 M9,3 L15,1" />
                        <TextBlock Text="Open MeowProof…" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuItemButton}" Click="Settings_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="13" Height="13" Stretch="Uniform" Margin="0,0,9,0"
                              Fill="{StaticResource TextDim}"
                              Data="M8,5 A3,3 0 1 0 8,11 A3,3 0 0 0 8,5 Z M8,1 V3 M8,13 V15 M1,8 H3 M13,8 H15 M3.22,3.22 L4.64,4.64 M11.36,11.36 L12.78,12.78 M3.22,12.78 L4.64,11.36 M11.36,4.64 L12.78,3.22" />
                        <TextBlock Text="Settings…" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Border BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,1,0,0"
                        Margin="4,4,4,4" />

                <Button Style="{StaticResource MenuItemButton}" Click="Quit_Click"
                        Foreground="{StaticResource TextDim}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="13" Height="13" Stretch="Uniform" Margin="0,0,9,0"
                              Stroke="{StaticResource TextDim}" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M8,3 V8 M12.24,4.76 A6,6 0 1 1 3.76,4.76" />
                        <TextBlock Text="Quit MeowProof" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>
