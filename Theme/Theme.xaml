<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Palette (MeowProof, warm "paper & terracotta" direction) ===== -->
    <Color x:Key="BgColor">#FBF7F1</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="Surface2Color">#F4EEE4</Color>
    <Color x:Key="Surface3Color">#EBE2D4</Color>
    <Color x:Key="BorderColor">#E9E0D2</Color>
    <Color x:Key="BorderSoftColor">#F0E9DC</Color>
    <Color x:Key="TextColor">#33302B</Color>
    <Color x:Key="TextDimColor">#8C8478</Color>
    <Color x:Key="TextFaintColor">#B3AA9A</Color>
    <Color x:Key="AccentColor">#CC7C57</Color>
    <Color x:Key="AccentDeepColor">#B0633F</Color>
    <Color x:Key="AccentSoftColor">#F6E7DC</Color>
    <Color x:Key="AccentGlowColor">#38CC7C57</Color>
    <Color x:Key="SageColor">#6E9E86</Color>
    <Color x:Key="SageGlowColor">#246E9E86</Color>
    <Color x:Key="GreenColor">#6BCB77</Color>
    <Color x:Key="RedColor">#D9645C</Color>

    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="Surface2" Color="{StaticResource Surface2Color}" />
    <SolidColorBrush x:Key="Surface3" Color="{StaticResource Surface3Color}" />
    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderSoft" Color="{StaticResource BorderSoftColor}" />
    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextDim" Color="{StaticResource TextDimColor}" />
    <SolidColorBrush x:Key="TextFaint" Color="{StaticResource TextFaintColor}" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDeep" Color="{StaticResource AccentDeepColor}" />
    <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="AccentGlow" Color="{StaticResource AccentGlowColor}" />
    <SolidColorBrush x:Key="Sage" Color="{StaticResource SageColor}" />
    <SolidColorBrush x:Key="SageGlow" Color="{StaticResource SageGlowColor}" />
    <SolidColorBrush x:Key="Green" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="Red" Color="{StaticResource RedColor}" />

    <FontFamily x:Key="UiFont">/Assets/Fonts/#Manrope</FontFamily>

    <!-- ===== Window chrome buttons (min / close) ===== -->
    <Style x:Key="WinButton" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="{StaticResource TextDim}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface2}" />
                            <Setter Property="Foreground" Value="{StaticResource Text}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WinCloseButton" TargetType="Button" BasedOn="{StaticResource WinButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Red}" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== iOS-style toggle switch ===== -->
    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track" Width="44" Height="24" CornerRadius="12"
                            Background="{StaticResource Surface3}" VerticalAlignment="Center">
                        <Canvas>
                            <Ellipse x:Name="Knob" Canvas.Left="3" Canvas.Top="3"
                                     Width="18" Height="18" Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.12"
                                                      BlurRadius="4" ShadowDepth="1" Direction="270" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}" />
                            <Setter TargetName="Knob" Property="Canvas.Left" Value="23" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Secondary button (icon + label) ===== -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="11">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface2}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Surface3}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
